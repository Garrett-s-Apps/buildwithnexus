FROM node:20-alpine

WORKDIR /app

# Minimal NEXUS container for testing
RUN echo "NEXUS test container" > /app/version.txt

EXPOSE 4200

HEALTHCHECK --interval=5s --timeout=3s --start-period=5s --retries=3 \
  CMD node -e "require('http').get('http://localhost:4200/health', (r) => {if (r.statusCode !== 200) throw new Error(r.statusCode)})" || exit 1

CMD ["node", "-e", "require('http').createServer((req, res) => { if (req.url === '/health') { res.writeHead(200); res.end(JSON.stringify({status: 'healthy'})); } else { res.writeHead(200); res.end('NEXUS'); } }).listen(4200, () => console.log('NEXUS running on :4200'))"]

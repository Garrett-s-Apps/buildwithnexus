# Supply-chain hardening defaults.
# - engine-strict: refuse to install on Node/npm versions outside engines field.
# - save-exact: writes pinned versions to package.json (caret ranges only via explicit decision).
# - audit=true: surface known vulnerabilities at install time.
# - fund=false: drop fund-message noise from install output.
# - ignore-scripts is intentionally NOT set globally — project's own postinstall
#   has been removed, but transitive deps still need their lifecycle scripts to
#   build native bindings. CI uses `npm ci --ignore-scripts` for hardened installs.
engine-strict=true
save-exact=true
audit=true
fund=false
package-lock=true
